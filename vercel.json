{
  "crons": [
    {
      "path": "/api/cron/pm-due",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/sanitation-due",
      "schedule": "0 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
